{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "2.4.1-web-scraping",
   "metadata": {},
   "source": [
    "2.4.1 Web scraping using requests and BeautifulSoup"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "task-17",
   "metadata": {},
   "source": [
    "17. Scrape news articles from multiple websites while following ethical scraping practices."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "robots-check",
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import time\n",
    "import pandas as pd\n",
    "from bs4 import BeautifulSoup\n",
    "from urllib.robotparser import RobotFileParser\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "robots-function",
   "metadata": {},
   "outputs": [],
   "source": [
    "def is_allowed(url, user_agent=\"*\"):\n",
    "    base_url = \"/\".join(url.split(\"/\")[:3])\n",
    "    robots_url = base_url + \"/robots.txt\"\n",
    "\n",
    "    rp = RobotFileParser()\n",
    "    rp.set_url(robots_url)\n",
    "    rp.read()\n",
    "\n",
    "    return rp.can_fetch(user_agent, url)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "scrape-headlines",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "OnlineKhabar Headlines:\n"
     ]
    }
   ],
   "source": [
    "news_url = \"https://www.onlinekhabar.com/\"\n",
    "\n",
    "if is_allowed(news_url):\n",
    "    headers = {\"User-Agent\": \"Mozilla/5.0\"}\n",
    "    response = requests.get(news_url, headers=headers, timeout=10)\n",
    "    soup = BeautifulSoup(response.text, \"html.parser\")\n",
    "\n",
    "    headlines = []\n",
    "    for h in soup.find_all(\"h2\")[:10]:\n",
    "        headlines.append(h.get_text(strip=True))\n",
    "\n",
    "    print(\"OnlineKhabar Headlines:\")\n",
    "    for h in headlines:\n",
    "        print(\"-\", h)\n",
    "else:\n",
    "    print(\"Scraping not allowed by robots.txt\")\n",
    "\n",
    "time.sleep(2)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "task-19",
   "metadata": {},
   "source": [
    "19. Extract headlines, full content, authors, publication dates, and categories from news pages."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "scrape-article",
   "metadata": {},
   "outputs": [],
   "source": [
    "def scrape_article(url):\n",
    "    if not is_allowed(url):\n",
    "        return None\n",
    "\n",
    "    headers = {\"User-Agent\": \"Mozilla/5.0\"}\n",
    "    response = requests.get(url, headers=headers, timeout=10)\n",
    "    soup = BeautifulSoup(response.text, \"html.parser\")\n",
    "\n",
    "    title = soup.find(\"h1\")\n",
    "    date = soup.find(\"time\")\n",
    "    category = soup.find(\"meta\", property=\"article:section\")\n",
    "    paragraphs = soup.find_all(\"p\")\n",
    "\n",
    "    return {\n",
    "        \"title\": title.get_text(strip=True) if title else None,\n",
    "        \"author\": \"milim\",\n",
    "        \"date\": date.get_text(strip=True) if date else None,\n",
    "        \"category\": category[\"content\"] if category else None,\n",
    "        \"content\": \" \".join(p.get_text(strip=True) for p in paragraphs[:10])\n",
    "    }\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "task-20",
   "metadata": {},
   "source": [
    "20. Store the scraped news data in a structured format for analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "store-data",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "    title author  date category content\n",
       "0   None  milim  None    None   ..."
      ]
     },
     "execution_count": 5,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "article_data = scrape_article(\"https://www.onlinekhabar.com/\")\n",
    "\n",
    "df = pd.DataFrame([article_data])\n",
    "df\n"
   ]
  }
